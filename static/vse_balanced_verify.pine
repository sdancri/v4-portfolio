// © sdancri — VSE Balanced verifier (Pine v6)
//
// Replică EXACTĂ a logicii de INTRARE din vse_bot (Python implementation).
// Doar pentru VERIFICARE vizuală pe TradingView — NU este strategy().
//
// Match cu bot-ul:
//   - 6 indicatori: McGinley(14) + White Line(20) + TTM Squeeze(20, BB×2, KC×2)
//                   + Tether(13/55) + Vortex(14, thr 0.05) + SuperTrend(ATR 22, ×3, wicks)
//   - Style "Balanced": baseline + 2-of-3 (TTMS, Tether, Vortex) + TTMS edge-trigger
//   - SL bounds: 0.5% .. 3.5%
//   - Cooldown: 3 bars post-signal (Pine nu poate replica post-EXIT fără strategy())
//
// Limitări vs bot live (acceptable pentru verificare):
//   - Cooldown e POST-SIGNAL (nu post-EXIT real cu OPP detection)
//   - Nu simulează cycle reset, SUCCESS withdraw, force-close
//   - Nu plotează exits (TS / OPP / EOD) — doar entries

//@version=6
indicator("VSE Balanced — verifier (read-only)", overlay=true, max_labels_count=500)

// ========== INPUTS ==========
g_ind = "Indicators (default match bot)"
mcg_len   = input.int(14, "McGinley Length",   group=g_ind)
wl_len    = input.int(20, "White Line Length", group=g_ind)
ttms_len  = input.int(20, "TTMS Length",       group=g_ind)
ttms_bb   = input.float(2.0, "TTMS BB Mult",   group=g_ind, step=0.1)
ttms_kc   = input.float(2.0, "TTMS KC Mult Widest", group=g_ind, step=0.1)
teth_f    = input.int(13, "Tether Fast",       group=g_ind)
teth_s    = input.int(55, "Tether Slow",       group=g_ind)
vor_len   = input.int(14, "Vortex Length",     group=g_ind)
vor_thr   = input.float(0.05, "Vortex Threshold", group=g_ind, step=0.01)
st_len    = input.int(22, "SuperTrend ATR Length", group=g_ind)
st_mult   = input.float(3.0, "SuperTrend Mult",    group=g_ind, step=0.1)
st_wicks  = input.bool(true, "SuperTrend Use Wicks (high/low)", group=g_ind)

g_filt = "Entry Filters"
sl_min_pct  = input.float(0.005, "SL min %", group=g_filt, step=0.001)
sl_max_pct  = input.float(0.035, "SL max %", group=g_filt, step=0.001)
cooldown    = input.int(3,    "Cooldown bars (post-signal)", group=g_filt)

g_disp = "Display"
show_supertrend = input.bool(true, "Plot SuperTrend trailing", group=g_disp)
show_baseline   = input.bool(true, "Plot McGinley baseline",   group=g_disp)
show_whiteline  = input.bool(false,"Plot White Line",          group=g_disp)


// ========== 1. McGINLEY DYNAMIC ==========
// mg[i] = mg[i-1] + (close - mg[i-1]) / (length * (close/mg[i-1])^4)
// Seed cu EMA pentru primele bare (Pine convention).
var float mg = na
ema_seed = ta.ema(close, mcg_len)
if na(mg[1]) or mg[1] == 0
    mg := ema_seed
else
    ratio = close / mg[1]
    denom = mcg_len * math.pow(ratio, 4)
    mg := denom == 0 or na(denom) ? mg[1] : mg[1] + (close - mg[1]) / denom
baseline       = mg
baseline_trend = close > baseline ? 1 : close < baseline ? -1 : 0


// ========== 2. WHITE LINE ==========
white_line  = (ta.highest(high, wl_len) + ta.lowest(low, wl_len)) / 2
white_trend = close > white_line ? 1 : close < white_line ? -1 : 0


// ========== 3. TTM SQUEEZE ==========
basis = ta.sma(close, ttms_len)
dev   = ta.stdev(close, ttms_len)
bb_up = basis + ttms_bb * dev
bb_dn = basis - ttms_bb * dev

// Keltner cu TR (NU ATR — fidel implementării bot)
tr_v   = ta.tr(true)
kc_dev = ta.sma(tr_v, ttms_len)
kc_up  = basis + kc_dev * ttms_kc
kc_dn  = basis - kc_dev * ttms_kc

no_squeeze = bb_dn < kc_dn or bb_up > kc_up

// Momentum (linreg)
hh        = ta.highest(high, ttms_len)
ll        = ta.lowest(low,  ttms_len)
price_avg = ((hh + ll) / 2 + basis) / 2
diff      = close - price_avg
ttms_mom  = ta.linreg(diff, ttms_len, 0)

// Green/red basic (rising positive / falling negative)
mom_prev  = ttms_mom[1]
ttms_l_b  = ttms_mom > 0 and ttms_mom > mom_prev
ttms_s_b  = ttms_mom < 0 and ttms_mom < mom_prev

// Highlight: require no_squeeze
ttms_l_sig = ttms_l_b and no_squeeze
ttms_s_sig = ttms_s_b and no_squeeze

// Edge-trigger (cross): True doar pe prima bară a semnalului
ttms_l_fin = ttms_l_sig and not ttms_l_sig[1]
ttms_s_fin = ttms_s_sig and not ttms_s_sig[1]


// ========== 4. TETHER LINE (dual) ==========
teth_fast_v = (ta.highest(high, teth_f) + ta.lowest(low, teth_f)) / 2
teth_slow_v = (ta.highest(high, teth_s) + ta.lowest(low, teth_s)) / 2
tether_long  = teth_fast_v > teth_slow_v and close > teth_slow_v
tether_short = teth_fast_v < teth_slow_v and close < teth_slow_v


// ========== 5. VORTEX ==========
vm_plus   = math.abs(high - low[1])
vm_minus  = math.abs(low  - high[1])
vplus     = math.sum(vm_plus,  vor_len)
vminus    = math.sum(vm_minus, vor_len)
sum_tr    = math.sum(tr_v,     vor_len)
vi_plus   = vplus  / sum_tr
vi_minus  = vminus / sum_tr
vortex_long  = (vi_plus  - vi_minus) > vor_thr
vortex_short = (vi_minus - vi_plus)  > vor_thr


// ========== 6. SUPERTREND (ATR 22 × 3, wicks=true) ==========
hl2_v  = (high + low) / 2
atr_st = ta.atr(st_len)
sdv    = st_mult * atr_st
hp     = st_wicks ? high : close
lp     = st_wicks ? low  : close

var float st_long  = na
var float st_short = na
var int   st_dir   = 1

cl_v = hl2_v - sdv
cs_v = hl2_v + sdv
pls  = nz(st_long[1],  cl_v)
pss  = nz(st_short[1], cs_v)
plo  = nz(lp[1], lp)
phi  = nz(hp[1], hp)

st_long  := plo > pls ? math.max(cl_v, pls) : cl_v
st_short := phi < pss ? math.min(cs_v, pss) : cs_v

if st_dir == -1 and hp > pss
    st_dir := 1
else if st_dir == 1 and lp < pls
    st_dir := -1


// ========== BUILD RAW SIGNALS (Balanced) ==========
bl_up = baseline_trend ==  1
bl_dn = baseline_trend == -1

count_l = (ttms_l_fin ? 1 : 0) + (tether_long  ? 1 : 0) + (vortex_long  ? 1 : 0)
count_s = (ttms_s_fin ? 1 : 0) + (tether_short ? 1 : 0) + (vortex_short ? 1 : 0)

// Balanced: baseline + 2-of-3 + TTMS edge-trigger explicit
raw_long  = bl_up and count_l >= 2 and ttms_l_fin
raw_short = bl_dn and count_s >= 2 and ttms_s_fin


// ========== ENTRY FILTERS (SL bounds + cooldown) ==========
var int last_sig_bar = na

cooldown_ok = na(last_sig_bar) or (bar_index - last_sig_bar) >= cooldown
indicators_ready = not na(atr_st) and not na(st_long) and not na(st_short)

sl_long_dist  = (close - st_long)  / close
sl_short_dist = (st_short - close) / close

entry_long  = raw_long  and indicators_ready and cooldown_ok and st_long  < close and sl_long_dist  >= sl_min_pct and sl_long_dist  <= sl_max_pct
entry_short = raw_short and indicators_ready and cooldown_ok and st_short > close and sl_short_dist >= sl_min_pct and sl_short_dist <= sl_max_pct

if entry_long or entry_short
    last_sig_bar := bar_index


// ========== PLOTS ==========
plot(show_baseline   ? baseline   : na, title="McGinley", color=color.new(color.yellow, 0), linewidth=2)
plot(show_whiteline  ? white_line : na, title="White Line", color=color.new(color.white, 0), linewidth=1)

plot(show_supertrend and st_dir ==  1 ? st_long  : na, title="ST Long stop",  color=color.new(color.lime, 0),   style=plot.style_linebr, linewidth=2)
plot(show_supertrend and st_dir == -1 ? st_short : na, title="ST Short stop", color=color.new(color.red, 0),    style=plot.style_linebr, linewidth=2)

plotshape(entry_long,  title="Long entry",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="L")
plotshape(entry_short, title="Short entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,  0), size=size.small, text="S")


// ========== ALERTS (opțional) ==========
alertcondition(entry_long,  title="VSE Long Entry",  message="VSE long entry on {{ticker}} {{interval}} @ {{close}}")
alertcondition(entry_short, title="VSE Short Entry", message="VSE short entry on {{ticker}} {{interval}} @ {{close}}")
