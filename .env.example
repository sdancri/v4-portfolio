# === Bybit API (Trade ENABLED, Withdraw DISABLED) ===
# SUB1_* sunt mapate în VSE_1 → BYBIT_API_KEY/SECRET (intern container)
# SUB2_* sunt mapate în VSE_2 → BYBIT_API_KEY/SECRET (intern container)
# Fiecare container vede DOAR cheile subaccount-ului lui (least privilege).
SUB1_API_KEY=
SUB1_API_SECRET=
SUB2_API_KEY=
SUB2_API_SECRET=

# === Mode ===
# ⚠️ live = banii sunt REALI pe Bybit mainnet. Setează "testnet" pentru paper.
TRADING_MODE=live        # testnet | live

# === Per-process (override prin docker-compose) ===
# Când rulezi un singur proces:
#   SUBACCOUNT_NAME=subacc_1_kaia_aave   sau   subacc_2_ont_eth
#   BOT_NAME=VSE_1                        sau   VSE_2
#   CHART_PORT=8101                        sau   8102
SUBACCOUNT_NAME=subacc_1_kaia_aave
BOT_NAME=VSE_1
CHART_PORT=8101

# === Telegram (opțional — gol = dezactivat) ===
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
