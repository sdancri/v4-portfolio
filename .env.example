# === Bybit API (Trade ENABLED, Withdraw DISABLED) ===
# Subaccount-ul folosit pentru ICHIMOKU bot (MNT + DOT 4h).
BYBIT_API_KEY=
BYBIT_API_SECRET=

# === Mode ===
# ⚠️ live = banii sunt REALI pe Bybit mainnet. Seteaza "testnet" pentru paper.
TRADING_MODE=live        # testnet | live

# === Telegram (optional — gol = dezactivat) ===
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# === Override-uri (rar folosite) ===
# Daca vrei alt nume bot sau alt port chart:
# BOT_NAME=ichimoku_mnt_dot
# CHART_PORT=8103
