# ============================================================================
# ICHIMOKU bot — Environment variables (Portainer / docker compose)
# ============================================================================
# Copiaza acest fisier ca `.env` in directorul stack-ului (sau lipeste
# valorile direct in Portainer → Environment variables) si completeaza.

# ── REQUIRED — Bybit credentials (Trade ENABLED, Withdraw DISABLED) ─────────
# Subaccount-ul folosit pentru ICHIMOKU bot (MNT + DOT 4h).
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── REQUIRED — Trading mode ─────────────────────────────────────────────────
# ⚠️ "live" = bani REALI pe Bybit mainnet. Recomandat: porneste pe "testnet"
# 2-4 saptamani inainte de live. Default in compose este "testnet" (siguranta).
TRADING_MODE=testnet

# ── OPTIONAL — Telegram notifications ───────────────────────────────────────
# Lasa goale pentru a dezactiva Telegram (bot-ul merge fara probleme).
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── OPTIONAL — Branding & display ───────────────────────────────────────────
# Toate au default-uri sensibile in compose; override doar daca vrei.
# BOT_NAME=ichimoku_mnt_dot                # Telegram header label
# STRATEGY_NAME=Hull+Ichimoku              # chart label
# CHART_PORT=8103                          # port HTTP pt chart UI
# CHART_TZ=Europe/Bucharest                # timezone pt chart + Telegram

# ── OPTIONAL — Rate limiter (Bybit V5: 10 req/s signed, 24 req/s public) ───
# Defaults conservative (5/s, burst 10) — lasa margine pt WS pings.
# Daca strategia ta ar avea volum mare de orders/min, urca-le.
# RATE_LIMIT_PER_SEC=5
# RATE_LIMIT_BURST=10

# ── OPTIONAL — Maker entry pattern timeout ─────────────────────────────────
# Cat asteapta PostOnly limit la entry inainte de fallback Market.
# 4h TF: 5s e OK. Pe TF-uri scurte (5m), poate vrei 2-3s.
# MAKER_ENTRY_TIMEOUT_SEC=5
