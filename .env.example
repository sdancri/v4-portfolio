# === Bybit API (Trade ENABLED, Withdraw DISABLED) ===
SUB1_API_KEY=
SUB1_API_SECRET=
SUB2_API_KEY=
SUB2_API_SECRET=

# Master account (opțional, pentru auto-transfer la SUCCESS)
MASTER_API_KEY=
MASTER_API_SECRET=

# === Mode ===
TRADING_MODE=testnet     # testnet | live

# === Per-process (override prin docker-compose) ===
# Când rulezi un singur proces:
#   SUBACCOUNT_NAME=subacc_1_kaia_aave   sau   subacc_2_ont_eth
#   BOT_NAME=vse_sub1_kaia_aave           sau   vse_sub2_ont_eth
#   CHART_PORT=8101                        sau   8102
SUBACCOUNT_NAME=subacc_1_kaia_aave
BOT_NAME=vse_sub1_kaia_aave
CHART_PORT=8101

# === Telegram (opțional — gol = dezactivat) ===
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
